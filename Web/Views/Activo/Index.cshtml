@using Dominio

@model List<Activo>



<table class="table">
    <thead>
        <tr>
            <th>
                Codigo
            </th>
            <th>
                Nombre
            </th>
            <th>
                Tipo
            </th>
            <th>
                Criticidad
            </th>
            <th>
                Backup
            </th>

            
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>

                <td>
                    @item.Codigo
                </td>
                <td>
                    @item.Nombre
                </td>
                <td>
                    @item.Tipo
                </td>
                <td>
                    @item.Criticidad
                </td>
                <td>
                    @item.Backup
                </td>

                
            </tr>
        }
    </tbody>
</table>